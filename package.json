{
  "name": "adelina-pms",
  "version": "0.1.0",
  "private": true,
  "description": "PMS multi-tenant com channel manager bidirecional (Airbnb/Booking)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @adelina/api dev",
    "dev:web": "pnpm --filter @adelina/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @adelina/db generate",
    "db:migrate": "pnpm --filter @adelina/db migrate",
    "db:push": "pnpm --filter @adelina/db push",
    "db:studio": "pnpm --filter @adelina/db studio",
    "db:seed": "pnpm --filter @adelina/db seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.16.0",
      "glob@10": "^10.5.0",
      "lodash": "^4.17.23",
      "postcss": "^8.5.10"
    }
  }
}
