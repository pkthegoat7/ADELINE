{
  "name": "@adelina/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "build": "nest build && mkdir -p dist/modules/legal && cp -r src/modules/legal/content dist/modules/legal/content",
    "start": "node dist/main.js",
    "start:local": "dotenv -e ../../.env -- node dist/main.js",
    "start:worker": "node dist/worker.js",
    "dev:worker": "dotenv -e ../../.env -- tsx watch src/worker.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@adelina/db": "workspace:*",
    "@fastify/helmet": "^11",
    "@fastify/static": "^7.0.4",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/platform-fastify": "^10.4.7",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/swagger": "^8.0.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.25.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "fastify": "^4.28.1",
    "ical-generator": "^7.2.0",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^3.1.0",
    "node-ical": "^0.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.7",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
